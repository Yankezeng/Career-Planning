# ============================================================
# HuggingFace 模型配置（本地缓存 + 懒加载 + 自动降级）
# ============================================================
# 是否启用 embedding 意图分类（设为 false 可完全跳过 HF 模型）
ENABLE_INTENT_EMBEDDING=true
# 是否启用 RAG reranker（设为 false 可完全跳过 reranker）
ENABLE_RAG_RERANKER=true
# 首次使用时是否自动从 HuggingFace 下载模型到本地
HF_MODEL_AUTO_DOWNLOAD=true
# 严格只从本地目录加载模型，禁止联网下载
HF_MODEL_LOCAL_FILES_ONLY=false
# 离线模式：运行时避免访问 HuggingFace Hub
HF_HUB_OFFLINE=false
# Embedding 模型名称（HuggingFace repo id）
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Reranker 模型名称（HuggingFace repo id）
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Embedding 模型本地存储目录（相对于项目根目录）
EMBEDDING_MODEL_DIR=./models/embedding
# Reranker 模型本地存储目录（相对于项目根目录）
RERANKER_MODEL_DIR=./models/reranker
# HuggingFace Hub Token（可选，public 模型无需填写；private/gated 模型必须填写）
HF_TOKEN=
# 模型下载超时时间（秒）
MODEL_DOWNLOAD_TIMEOUT=120
