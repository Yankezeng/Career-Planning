SECRET_KEY=change-me
DATABASE_URL=sqlite:///career_agent_local.db
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Local Milvus Lite file, or replace with http://127.0.0.1:19530 for a remote Milvus server.
MILVUS_URI=uploads/milvus/job_knowledge_base.db
MILVUS_JOB_COLLECTION=job_knowledge_base
MILVUS_TOKEN=

# LangChain / DashScope-compatible settings.
LANGCHAIN_PROVIDER=dashscope-compatible
LANGCHAIN_MODEL=qwen-plus
LANGCHAIN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LANGCHAIN_TEMPERATURE=0.2
DASHSCOPE_API_KEY=
RESUME_VISION_MODEL=qwen-vl-plus
RESUME_OCR_LANG=chi_sim+eng

# Agent API keys. Fill these locally; do not commit real keys.
FILE_AGENT_API_KEY=
FILE_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
FILE_AGENT_MODULE_NAME=qwen3.5-omni-plus-2026-03-15
SUPERVISOR_AGENT_API_KEY=
SUPERVISOR_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
