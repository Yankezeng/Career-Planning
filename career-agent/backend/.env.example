# HuggingFace model settings. The model files themselves are not committed.
ENABLE_INTENT_EMBEDDING=true
ENABLE_RAG_RERANKER=true
HF_MODEL_AUTO_DOWNLOAD=true
HF_MODEL_LOCAL_FILES_ONLY=false
HF_HUB_OFFLINE=false
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EMBEDDING_MODEL_DIR=./models/embedding
RERANKER_MODEL_DIR=./models/reranker
HF_TOKEN=
MODEL_DOWNLOAD_TIMEOUT=120
